# ── Rent-a-Whale environment ─────────────────────────────────────────────────
# Copy to .env and change every CHANGE_ME. The backend refuses to start in
# ENVIRONMENT=production while a CHANGE_ME value is present.

# General
ENVIRONMENT=development                 # development | production
PLATFORM_DOMAIN=localhost               # apps served at dep-<slug>.${PLATFORM_DOMAIN}
API_URL=http://api.localhost
FRONTEND_URL=http://app.localhost
LOG_LEVEL=INFO

# Security
SECRET_KEY=CHANGE_ME_64_random_chars
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
CORS_ORIGINS=http://app.localhost,http://localhost:5173

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=rentawhale
POSTGRES_USER=rentawhale
POSTGRES_PASSWORD=CHANGE_ME_db_password

# Redis
REDIS_URL=redis://redis:6379/0

# Docker provider
DEPLOYMENT_PROVIDER=docker
DOCKER_HOST_SOCKET=/var/run/docker.sock
INGRESS_NETWORK=raw_ingress
# Host capacity reserved for the platform itself (never rentable)
HOST_RESERVED_CPU_CORES=1
HOST_RESERVED_MEMORY_MB=2048
HOST_RESERVED_DISK_GB=10

# Billing
BILLING_TICK_SECONDS=60
MIN_BALANCE_HOURS=1                     # required balance = N hours of estimated cost

# Bootstrap admin (created by seed script if no admin exists)
FIRST_ADMIN_EMAIL=admin@example.com
FIRST_ADMIN_PASSWORD=CHANGE_ME_admin_password

# Traefik / TLS — set both to enable Let's Encrypt in production
ACME_EMAIL=
# TRAEFIK_TLS=true
